# Legacy Made - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED
# =============================================================================

# Clerk authentication - get from https://dashboard.clerk.com/
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# API server URL - use http://localhost:3000 for local development
EXPO_PUBLIC_API_URL=http://localhost:3000

# =============================================================================
# OPTIONAL - External Links
# =============================================================================
# These configure URLs to the Legacy Made website. All have sensible defaults
# pointing to https://mylegacymade.com. Only set these if you need to override.

# Base URL for all external links (defaults to https://mylegacymade.com)
# EXPO_PUBLIC_BASE_URL=https://mylegacymade.com

# Help/FAQ page
# EXPO_PUBLIC_HELP_URL=https://mylegacymade.com/help

# Contact support page
# EXPO_PUBLIC_SUPPORT_URL=https://mylegacymade.com/support

# Privacy policy page
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://mylegacymade.com/privacy-policy

# Terms of service page
# EXPO_PUBLIC_TERMS_URL=https://mylegacymade.com/terms-of-service

# Subscription upgrade page
# EXPO_PUBLIC_UPGRADE_URL=https://mylegacymade.com/upgrade
